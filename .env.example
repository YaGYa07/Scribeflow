# Copy to .env — encode @ in password as %40
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# Example if password is YagyaLipi@01:
# DATABASE_URL=postgresql://postgres:YagyaLipi%4001@db.YOUR_PROJECT.supabase.co:5432/postgres

# For Vercel (serverless), prefer Supabase "Transaction" pooler on port 6543:
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
