# Direct connection (local dev + drizzle migrate)
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Vercel / serverless — copy from Supabase → Connect → Transaction pooler (ap-south-1, port 6543)
DATABASE_URL_POOLED=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
SUPABASE_REGION=ap-south-1

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
AUTH_TRUST_HOST=true
